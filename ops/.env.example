# Copie para ops/.env e ajuste. ops/.env é ignorado pelo git.

# --- Persistência (bind mount dentro do projeto) ---
# Caminho relativo ao diretório ops/ (onde roda o compose). Default: ../data/volumes
DATA_DIR=../data/volumes

# --- PostgreSQL ---
POSTGRES_VERSION=16
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
POSTGRES_DB=rag
POSTGRES_PORT=5432

# --- Milvus (standalone) ---
MILVUS_VERSION=v2.5.4
MILVUS_PORT=19530
MILVUS_METRICS_PORT=9091

# --- Attu (UI web do Milvus) ---
ATTU_VERSION=v2.5
ATTU_PORT=3000

# --- etcd (metadados do Milvus) ---
ETCD_VERSION=v3.5.16

# --- MinIO (storage do Milvus) ---
# Mantenha o default minioadmin/minioadmin, ou ajuste também a config do Milvus.
MINIO_VERSION=RELEASE.2024-12-18T13-15-44Z
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
