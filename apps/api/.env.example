# Copie para apps/api/.env e ajuste. .env é ignorado pelo git. (ADR-0006: tudo por env)

# --- Banco (Postgres do ops/) ---
DATABASE_URL=postgresql+psycopg2://rag:rag@localhost:5432/rag

# --- Milvus (ops/) ---
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=rag_chunks

# --- Embeddings + LLM (LM Studio, API OpenAI-compatível) ---
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_API_KEY=lm-studio
EMBEDDING_MODEL=embeddinggemma-300m
EMBEDDING_DIM=768
CHAT_MODEL=local-chat-model

# --- Upload ---
UPLOAD_DIR=../../data/uploads
MAX_UPLOAD_MB=50

# --- Worker de ingestão (ADR-0004 / ADR-0009) ---
WORKER_POLL_INTERVAL=5
WORKER_HEARTBEAT_INTERVAL=30
WORKER_VISIBILITY_TIMEOUT=300
WORKER_MAX_ATTEMPTS=3
WORKER_RETRY_BACKOFF_BASE=60

# --- Retrieval ---
RETRIEVAL_TOP_K=5

# --- Vision (descrição de imagens durante ingestão — ADR-0012) ---
# VISION_ENABLED=true
# VISION_MODEL=gemma-3-4b-it-qat   # qualquer modelo vision carregado no LM Studio
# VISION_MAX_TOKENS=800            # maior = tabelas densas não truncam
# VISION_RENDER_DPI=200            # DPI do render da região da imagem (maior = mais legível, mais lento)
