# Copie para apps/api/.env e ajuste. .env é ignorado pelo git. (ADR-0006: tudo por env)

# --- Banco (Postgres do ops/) ---
DATABASE_URL=postgresql+psycopg2://rag:rag@localhost:5432/rag

# --- Milvus (ops/) ---
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=rag_chunks

# --- Embeddings + LLM (LM Studio, API OpenAI-compatível) ---
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_API_KEY=lm-studio
EMBEDDING_MODEL=embeddinggemma-300m
EMBEDDING_DIM=768
CHAT_MODEL=local-chat-model

# --- Upload ---
UPLOAD_DIR=../../data/uploads
MAX_UPLOAD_MB=50

# --- Worker de ingestão (ADR-0004 / ADR-0009) ---
WORKER_POLL_INTERVAL=5
WORKER_HEARTBEAT_INTERVAL=30
WORKER_VISIBILITY_TIMEOUT=300
WORKER_MAX_ATTEMPTS=3
WORKER_RETRY_BACKOFF_BASE=60

# --- Retrieval ---
RETRIEVAL_TOP_K=5
# RETRIEVAL_MIN_SCORE=0.3
# Vigência (ADR-0014): score de documentos vencidos (valid_until < hoje) × este fator; 1.0 desliga
# RETRIEVAL_EXPIRED_SCORE_FACTOR=0.5

# --- Chunking (default global; ADR-0002) ---
# CHUNK_SIZE_WORDS=350
# CHUNK_OVERLAP_WORDS=60

# Chunking por doc_type — omitir = usa os defaults globais acima (ADR-0013)
# CHUNK_SIZE_PROCEDIMENTO_RUNBOOK=150
# CHUNK_OVERLAP_PROCEDIMENTO_RUNBOOK=20
# CHUNK_SIZE_TRANSCRICAO_REUNIAO=200
# CHUNK_OVERLAP_TRANSCRICAO_REUNIAO=50
# CHUNK_SIZE_ATA_REUNIAO=200
# CHUNK_OVERLAP_ATA_REUNIAO=40
# CHUNK_SIZE_CODIGO_FONTE=120
# CHUNK_OVERLAP_CODIGO_FONTE=15
# CHUNK_SIZE_PLANILHA=80
# CHUNK_OVERLAP_PLANILHA=10
# CHUNK_SIZE_CONTRATO_LEGAL=500
# CHUNK_OVERLAP_CONTRATO_LEGAL=100
# CHUNK_SIZE_MANUAL_GUIA=400
# CHUNK_OVERLAP_MANUAL_GUIA=80
# CHUNK_SIZE_RELATORIO=400
# CHUNK_OVERLAP_RELATORIO=70
# CHUNK_SIZE_DOCUMENTO_TECNICO=350
# CHUNK_OVERLAP_DOCUMENTO_TECNICO=60
# CHUNK_SIZE_PROPOSTA_TECNICA=300
# CHUNK_OVERLAP_PROPOSTA_TECNICA=60
# CHUNK_SIZE_ESPECIFICACAO_REQUISITO=300
# CHUNK_OVERLAP_ESPECIFICACAO_REQUISITO=60
# CHUNK_SIZE_BASE_CONHECIMENTO=350
# CHUNK_OVERLAP_BASE_CONHECIMENTO=60
# CHUNK_SIZE_APRESENTACAO=300
# CHUNK_OVERLAP_APRESENTACAO=50

# --- Vision (descrição de imagens durante ingestão — ADR-0012) ---
# VISION_ENABLED=true
# VISION_MODEL=gemma-3-4b-it-qat   # qualquer modelo vision carregado no LM Studio
# VISION_MAX_TOKENS=800            # maior = tabelas densas não truncam
# VISION_RENDER_DPI=200            # DPI do render da região da imagem (maior = mais legível, mais lento)
